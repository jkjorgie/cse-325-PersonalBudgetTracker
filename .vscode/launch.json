{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch PersonalBudgetTracker",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/PersonalBudgetTracker/bin/Debug/net10.0/PersonalBudgetTracker.dll",
      "args": [],
      "cwd": "${workspaceFolder}/PersonalBudgetTracker",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7001;http://localhost:5185"
      }
    }
  ]
}
