@page "/account/register"

<PageTitle>Register</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Create Account</h2>

        @if (error is not null)
        {
            <div class="alert alert-danger">@Uri.UnescapeDataString(error)</div>
        }

        <form method="post" action="/account/register-post">
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" class="form-control" autocomplete="email" required />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" class="form-control" autocomplete="new-password" required minlength="6" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Register</button>
        </form>

        <p class="mt-3 text-center">
            Already have an account? <a href="/account/login">Login</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? error { get; set; }
}
