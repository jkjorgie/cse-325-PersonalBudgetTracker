@* expenses page *@

@page "/expenses"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthState
@inject ApplicationDbContext db
@inject IJSRuntime JS

@using PersonalBudgetTracker.Data
@using System.Security.Claims
@attribute [Authorize]

<PageTitle>Expenses</PageTitle>

<div class="container-fluid px-4">
    <h1 class="mt-4">Expenses</h1>
    <p class="text-muted">Record a new expense below.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <EditForm Model="Input" OnValidSubmit="OnSubmitForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label for="expense-category" class="form-label">Category <span class="text-danger">*</span></label>
                    <InputSelect id="expense-category" @bind-Value="Input.Category" class="form-select">
                        <option value="">-- Pick a category</option>
                        @foreach (string cat in TransactionCategories.All)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Input.Category" />
                </div>

                <div class="mb-3">
                    <label for="expense-amount" class="form-label">Amount <span class="text-danger">*</span></label>
                    <InputNumber id="expense-amount" @bind-Value="Input.Amount" class="form-control" />
                    <ValidationMessage For="() => Input.Amount" />
                </div>

                <div class="mb-3">
                    <label for="expense-date" class="form-label">Date <span class="text-danger">*</span></label>
                    <InputDate id="expense-date" @bind-Value="Input.Date" class="form-control" />
                    <ValidationMessage For="() => Input.Date" />
                </div>

                <div class="mb-3">
                    <label for="expense-description" class="form-label">Description</label>
                    <InputText id="expense-description" @bind-Value="Input.Description" class="form-control" />
                    <ValidationMessage For="() => Input.Description" />
                </div>

                <button type="submit" class="btn btn-primary">Enter Expense</button>
            </EditForm>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 fs-4">Your Expenses</h2>
        <div class="btn-group btn-group-sm" role="group" aria-label="View mode">
            <button type="button" class="btn @(viewMode == "card" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => viewMode = "card"'>
                Cards
            </button>
            <button type="button" class="btn @(viewMode == "table" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => viewMode = "table"'>
                Table
            </button>
        </div>
    </div>

    @if (!expenses.Any())
    {
        <p class="text-muted">No expenses recorded yet.</p>
    }
    else if (viewMode == "card")
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
            @foreach (var item in expenses)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (editingTransaction?.TransactionId == item.TransactionId)
                        {
                            <div class="card-body">
                                <div class="mb-2">
                                    <label for="edit-cat-@item.TransactionId" class="form-label small fw-semibold">Category</label>
                                    <InputSelect id="@($"edit-cat-{item.TransactionId}")" @bind-Value="item.Category" class="form-select form-select-sm">
                                        @foreach (var cat in TransactionCategories.All)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="mb-2">
                                    <label for="edit-amt-@item.TransactionId" class="form-label small fw-semibold">Amount</label>
                                    <InputNumber id="@($"edit-amt-{item.TransactionId}")" @bind-Value="item.Amount" class="form-control form-control-sm" />
                                </div>
                                <div class="mb-2">
                                    <label for="edit-date-@item.TransactionId" class="form-label small fw-semibold">Date</label>
                                    <InputDate id="@($"edit-date-{item.TransactionId}")" @bind-Value="item.Date" class="form-control form-control-sm" />
                                </div>
                                <div class="mb-3">
                                    <label for="edit-desc-@item.TransactionId" class="form-label small fw-semibold">Description</label>
                                    <InputText id="@($"edit-desc-{item.TransactionId}")" @bind-Value="item.Description" class="form-control form-control-sm" />
                                </div>
                                <button class="btn btn-success btn-sm me-1" type="button" @onclick="() => SaveEdit(item)">Save</button>
                                <button class="btn btn-secondary btn-sm" type="button" @onclick="CancelEdit">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge bg-secondary">@item.Category</span>
                                    <span class="fw-bold text-danger">₱@item.Amount.ToString("N2")</span>
                                </div>
                                <p class="card-text text-muted small mb-1">@item.Date.ToShortDateString()</p>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="card-text small">@item.Description</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent d-flex gap-2">
                                <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => StartEdit(item)">Edit</button>
                                <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => DeleteExpense(item.TransactionId)">Delete</button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Category</th>
                        <th scope="col">Amount</th>
                        <th scope="col">Description</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in expenses)
                    {
                        <tr>
                            @if (editingTransaction?.TransactionId == item.TransactionId)
                            {
                                <td>
                                    <label for="tbl-date-@item.TransactionId" class="visually-hidden">Date</label>
                                    <InputDate id="@($"tbl-date-{item.TransactionId}")" @bind-Value="item.Date" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <label for="tbl-cat-@item.TransactionId" class="visually-hidden">Category</label>
                                    <InputSelect id="@($"tbl-cat-{item.TransactionId}")" @bind-Value="item.Category" class="form-select form-select-sm">
                                        @foreach (var cat in TransactionCategories.All)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </InputSelect>
                                </td>
                                <td>
                                    <label for="tbl-amt-@item.TransactionId" class="visually-hidden">Amount</label>
                                    <InputNumber id="@($"tbl-amt-{item.TransactionId}")" @bind-Value="item.Amount" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <label for="tbl-desc-@item.TransactionId" class="visually-hidden">Description</label>
                                    <InputText id="@($"tbl-desc-{item.TransactionId}")" @bind-Value="item.Description" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <button class="btn btn-success btn-sm me-1" type="button" @onclick="() => SaveEdit(item)">Save</button>
                                    <button class="btn btn-secondary btn-sm" type="button" @onclick="CancelEdit">Cancel</button>
                                </td>
                            }
                            else
                            {
                                <td>@item.Date.ToShortDateString()</td>
                                <td>@item.Category</td>
                                <td class="text-danger fw-bold">₱@item.Amount.ToString("N2")</td>
                                <td>@item.Description</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm me-1" type="button" @onclick="() => StartEdit(item)">Edit</button>
                                    <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => DeleteExpense(item.TransactionId)">Delete</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {

    private Transaction Input { get; set; } = new() { Date = DateTime.Today };
    private List<Transaction> expenses = new();
    private Transaction? editingTransaction = null;
    private string viewMode = "card";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
            viewMode = width >= 768 ? "table" : "card";
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadExpenses();
    }

    private async Task LoadExpenses()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId is null) return;

        expenses = await db.Transactions
            .Where(t => t.UserId == userId && t.Type == TransactionType.Expense)
            .OrderByDescending(t => t.Date)
            .ToListAsync();
    }

    private async Task OnSubmitForm()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId is null) return;

        Input.UserId = userId;
        Input.Type = TransactionType.Expense;

        db.Transactions.Add(Input);
        await db.SaveChangesAsync();

        Input = new() { Date = DateTime.Today };
        await LoadExpenses();
    }

    private void StartEdit(Transaction transaction)
    {
        editingTransaction = transaction;
        StateHasChanged();
    }

    private void CancelEdit()
    {
        editingTransaction = null;
    }

    private async Task SaveEdit(Transaction transaction)
    {
        db.Transactions.Update(transaction);
        await db.SaveChangesAsync();

        editingTransaction = null;
        await LoadExpenses();
        StateHasChanged();
    }

    private async Task DeleteExpense(int id)
    {
        var transaction = await db.Transactions.FirstOrDefaultAsync(t => t.TransactionId == id);

        if (transaction != null)
        {
            db.Transactions.Remove(transaction);
            await db.SaveChangesAsync();

            await LoadExpenses();
            StateHasChanged();
        }
    }
}
