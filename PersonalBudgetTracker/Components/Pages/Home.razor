@page "/"

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid px-4">
    <h1 class="mt-4">Dashboard</h1>
    <p class="text-muted">Welcome to your Personal Budget Tracker.</p>

    <div class="row mt-4">
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Expense Transactions</h5>
                    <p class="card-text text-muted">Log and track your expenses by category.</p>
                    <a href="/expenses" class="btn btn-primary">Go to Expenses</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Income</h5>
                    <p class="card-text text-muted">Record and manage your income sources.</p>
                    <a href="/income" class="btn btn-primary">Go to Income</a>
                </div>
            </div>
        </div>
    </div>
</div>
