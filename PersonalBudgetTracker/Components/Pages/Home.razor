@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using PersonalBudgetTracker.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext Db

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid px-4">
    <h1 class="mt-4">Dashboard</h1>
    <p class="text-muted">@DateTime.Now.ToString("MMMM yyyy")</p>

    @if (!loaded)
    {
        <p class="text-muted">Loading...</p>
    }
    else
    {
        <!-- Net Summary -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-success bg-opacity-10 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">Income This Month</div>
                        <div class="fs-4 fw-bold text-success">₱@totalIncome.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-danger bg-opacity-10 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">Expenses This Month</div>
                        <div class="fs-4 fw-bold text-danger">₱@totalExpenses.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-12 col-lg-6">
                <div class="card shadow-sm border-0 h-100 @(net >= 0 ? "bg-success" : "bg-danger") bg-opacity-10">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">Net This Month</div>
                        <div class="fs-3 fw-bold @(net >= 0 ? "text-success" : "text-danger")">
                            @(net >= 0 ? "+" : "")₱@net.ToString("N2")
                        </div>
                        <div class="text-muted small mt-1">
                            @if (net > 0)
                            {
                                <span>You're ahead this month.</span>
                            }
                            else if (net < 0)
                            {
                                <span>Expenses exceed income this month.</span>
                            }
                            else
                            {
                                <span>Breaking even this month.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Breakdowns -->
        <div class="row g-3 mb-4">

            <!-- Income by Category -->
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold">Income by Category</div>
                    <div class="card-body">
                        @if (!incomeByCategory.Any())
                        {
                            <p class="text-muted small mb-0">No income recorded this month.</p>
                        }
                        else
                        {
                            @foreach (var item in incomeByCategory)
                            {
                                var pct = totalIncome > 0 ? (int)(item.Value / totalIncome * 100) : 0;
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small fw-semibold">@item.Key</span>
                                        <span class="small text-success fw-bold">₱@item.Value.ToString("N2") <span class="text-muted fw-normal">(@pct%)</span></span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-success" style="width: @pct%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/income" class="btn btn-sm btn-outline-success">View Income</a>
                    </div>
                </div>
            </div>

            <!-- Expenses by Category -->
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold">Expenses by Category</div>
                    <div class="card-body">
                        @if (!expensesByCategory.Any())
                        {
                            <p class="text-muted small mb-0">No expenses recorded this month.</p>
                        }
                        else
                        {
                            @foreach (var item in expensesByCategory)
                            {
                                var pct = totalExpenses > 0 ? (int)(item.Value / totalExpenses * 100) : 0;
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small fw-semibold">@item.Key</span>
                                        <span class="small text-danger fw-bold">₱@item.Value.ToString("N2") <span class="text-muted fw-normal">(@pct%)</span></span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-danger" style="width: @pct%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/expenses" class="btn btn-sm btn-outline-danger">View Expenses</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">Recent Transactions</div>
                    <div class="card-body p-0">
                        @if (!recentTransactions.Any())
                        {
                            <p class="text-muted small p-3 mb-0">No transactions yet.</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var t in recentTransactions)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge @(t.Type == TransactionType.Income ? "bg-success" : "bg-secondary") me-2">@t.Category</span>
                                            <span class="small text-muted">@t.Date.ToShortDateString()</span>
                                            @if (!string.IsNullOrEmpty(t.Description))
                                            {
                                                <span class="small text-muted ms-2">— @t.Description</span>
                                            }
                                        </div>
                                        <span class="fw-bold @(t.Type == TransactionType.Income ? "text-success" : "text-danger")">
                                            @(t.Type == TransactionType.Income ? "+" : "-")₱@t.Amount.ToString("N2")
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {

    private bool loaded = false;
    private decimal totalIncome;
    private decimal totalExpenses;
    private decimal net;
    private Dictionary<string, decimal> incomeByCategory = new();
    private Dictionary<string, decimal> expensesByCategory = new();
    private List<Transaction> recentTransactions = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId is null) return;

        var now = DateTime.Today;
        var monthStart = new DateTime(now.Year, now.Month, 1);
        var monthEnd = monthStart.AddMonths(1);

        var monthTransactions = await Db.Transactions
            .Where(t => t.UserId == userId && t.Date >= monthStart && t.Date < monthEnd)
            .ToListAsync();

        totalIncome = monthTransactions
            .Where(t => t.Type == TransactionType.Income)
            .Sum(t => t.Amount);

        totalExpenses = monthTransactions
            .Where(t => t.Type == TransactionType.Expense)
            .Sum(t => t.Amount);

        net = totalIncome - totalExpenses;

        incomeByCategory = monthTransactions
            .Where(t => t.Type == TransactionType.Income)
            .GroupBy(t => t.Category)
            .OrderByDescending(g => g.Sum(t => t.Amount))
            .ToDictionary(g => g.Key, g => g.Sum(t => t.Amount));

        expensesByCategory = monthTransactions
            .Where(t => t.Type == TransactionType.Expense)
            .GroupBy(t => t.Category)
            .OrderByDescending(g => g.Sum(t => t.Amount))
            .ToDictionary(g => g.Key, g => g.Sum(t => t.Amount));

        recentTransactions = await Db.Transactions
            .Where(t => t.UserId == userId)
            .OrderByDescending(t => t.Date)
            .Take(8)
            .ToListAsync();

        loaded = true;
        StateHasChanged();
    }
}
