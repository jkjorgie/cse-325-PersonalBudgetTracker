@* this page handles the income entry page *@

@page "/income"
@rendermode InteractiveServer
@using PersonalBudgetTracker.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext Db
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Income</PageTitle>

<div class="container-fluid px-4">
    <h1 class="mt-4">Income</h1>
    <p class="text-muted">Record a new income entry below.</p>

    @* enter new transaction form *@
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <EditForm Model="newTransaction" OnValidSubmit="AddIncome" FormName="IncomeForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label for="income-category" class="form-label">Category <span class="text-danger">*</span></label>
                    <InputSelect id="income-category" @bind-Value="newTransaction.Category" class="form-select">
                        @foreach (var cat in IncomeCategories.All)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => newTransaction.Category" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                    <InputNumber @bind-Value="newTransaction.Amount" class="form-control" />
                    </div>
                    <ValidationMessage For="() => newTransaction.Amount" />
                </div>

                <div class="mb-3">
                    <label for="income-date" class="form-label">Date <span class="text-danger">*</span></label>
                    <InputDate id="income-date" @bind-Value="newTransaction.Date" class="form-control" />
                    <ValidationMessage For="() => newTransaction.Date" />
                </div>

                <div class="mb-3">
                    <label for="income-description" class="form-label">Description</label>
                    <InputText id="income-description" @bind-Value="newTransaction.Description" class="form-control" />
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Add Income</button>
                    <button type="button" class="btn btn-secondary flex-sm-grow-0" @onclick="ResetForm">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>

    @* header of income transaction display. user can toggle between grid and card view *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 fs-4">Your Income</h2>
        <div class="btn-group btn-group-sm" role="group" aria-label="View mode">
            <button type="button" class="btn @(viewMode == "card" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => viewMode = "card"'>
                Cards
            </button>
            <button type="button" class="btn @(viewMode == "table" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => viewMode = "table"'>
                Table
            </button>
        </div>
    </div>

    @* card/grid display of income transactions *@
    @if (!incomes.Any())
    {
        <p class="text-muted">No income recorded yet.</p>
    }
    else if (viewMode == "card")
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
            @foreach (var item in incomes)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (editingTransaction?.TransactionId == item.TransactionId)
                        {
                            <div class="card-body">
                                <div class="mb-2">
                                    <label for="edit-cat-@item.TransactionId" class="form-label small fw-semibold">Category</label>
                                    <InputSelect id="@($"edit-cat-{item.TransactionId}")" @bind-Value="item.Category" class="form-select form-select-sm">
                                        @foreach (var cat in IncomeCategories.All)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="mb-2">
                                    <label for="edit-amt-@item.TransactionId" class="form-label small fw-semibold">Amount</label>
                                    <InputNumber id="@($"edit-amt-{item.TransactionId}")" @bind-Value="item.Amount" class="form-control form-control-sm" />
                                </div>
                                <div class="mb-2">
                                    <label for="edit-date-@item.TransactionId" class="form-label small fw-semibold">Date</label>
                                    <InputDate id="@($"edit-date-{item.TransactionId}")" @bind-Value="item.Date" class="form-control form-control-sm" />
                                </div>
                                <div class="mb-3">
                                    <label for="edit-desc-@item.TransactionId" class="form-label small fw-semibold">Description</label>
                                    <InputText id="@($"edit-desc-{item.TransactionId}")" @bind-Value="item.Description" class="form-control form-control-sm" />
                                </div>
                                <button class="btn btn-success btn-sm me-1" type="button" @onclick="() => SaveEdit(item)">Save</button>
                                <button class="btn btn-secondary btn-sm" type="button" @onclick="CancelEdit">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge bg-secondary">@item.Category</span>
                                    <span class="fw-bold text-success">₱@item.Amount.ToString("N2")</span>
                                </div>
                                <p class="card-text text-muted small mb-1">@item.Date.ToShortDateString()</p>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="card-text small">@item.Description</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent">
                                <button class="btn btn-outline-primary btn-sm me-2" type="button" @onclick="() => StartEdit(item)">Edit</button>
                                <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => DeleteIncome(item.TransactionId)">Delete</button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Category</th>
                        <th scope="col">Amount</th>
                        <th scope="col">Description</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in incomes)
                    {
                        <tr>
                            @if (editingTransaction?.TransactionId == item.TransactionId)
                            {
                                <td>
                                    <label for="tbl-date-@item.TransactionId" class="visually-hidden">Date</label>
                                    <InputDate id="@($"tbl-date-{item.TransactionId}")" @bind-Value="item.Date" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <label for="tbl-cat-@item.TransactionId" class="visually-hidden">Category</label>
                                    <InputSelect id="@($"tbl-cat-{item.TransactionId}")" @bind-Value="item.Category" class="form-select form-select-sm">
                                        @foreach (var cat in IncomeCategories.All)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </InputSelect>
                                </td>
                                <td>
                                    <label for="tbl-amt-@item.TransactionId" class="visually-hidden">Amount</label>
                                    <InputNumber id="@($"tbl-amt-{item.TransactionId}")" @bind-Value="item.Amount" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <label for="tbl-desc-@item.TransactionId" class="visually-hidden">Description</label>
                                    <InputText id="@($"tbl-desc-{item.TransactionId}")" @bind-Value="item.Description" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <button class="btn btn-success btn-sm me-1" type="button" @onclick="() => SaveEdit(item)">Save</button>
                                    <button class="btn btn-secondary btn-sm" type="button" @onclick="CancelEdit">Cancel</button>
                                </td>
                            }
                            else
                            {
                                <td>@item.Date.ToShortDateString()</td>
                                <td>@item.Category</td>
                                <td class="text-success fw-bold">₱@item.Amount.ToString("N2")</td>
                                <td>@item.Description</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm me-1" type="button" @onclick="() => StartEdit(item)">Edit</button>
                                    <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => DeleteIncome(item.TransactionId)">Delete</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {

    private Transaction newTransaction = new()
    {
        Date = DateTime.Today,
        Type = TransactionType.Income,
        Category = IncomeCategories.All[0]
    };

    private List<Transaction> incomes = new();
    private Transaction? editingTransaction = null;
    private string viewMode = "card";

    private void ResetForm()
    {
        newTransaction = new()
        {
            Date = DateTime.Today,
            Type = TransactionType.Income,
            Category = IncomeCategories.All[0]
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
            viewMode = width >= 768 ? "table" : "card";
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadIncome();
    }

    private async Task<string?> GetUserId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task LoadIncome()
    {
        var userId = await GetUserId();
        if (userId is null) return;

        incomes = await Db.Transactions
            .Where(t => t.UserId == userId && t.Type == TransactionType.Income)
            .OrderByDescending(t => t.Date)
            .ToListAsync();
    }

    private async Task AddIncome()
    {
        var userId = await GetUserId();
        if (userId is null) return;

        newTransaction.UserId = userId;
        newTransaction.Type = TransactionType.Income;

        Db.Transactions.Add(newTransaction);
        await Db.SaveChangesAsync();

        newTransaction = new Transaction
        {
            Date = DateTime.Today,
            Type = TransactionType.Income,
            Category = IncomeCategories.All[0]
        };

        await LoadIncome();
    }

    private void StartEdit(Transaction transaction)
    {
        editingTransaction = transaction;
        StateHasChanged();
    }

    private async Task CancelEdit()
    {
        editingTransaction = null;
        await LoadIncome();
    }

    private async Task SaveEdit(Transaction transaction)
    {
        Db.Transactions.Update(transaction);
        await Db.SaveChangesAsync();

        editingTransaction = null;
        await LoadIncome();
        StateHasChanged();
    }

    private async Task DeleteIncome(int id)
    {
        var transaction = await Db.Transactions.FirstOrDefaultAsync(t => t.TransactionId == id);

        if (transaction != null)
        {
            Db.Transactions.Remove(transaction);
            await Db.SaveChangesAsync();

            await LoadIncome();
            StateHasChanged();
        }
    }
}
